PORT=3040
# SQLite file (default ./data/dominance.db)
DATABASE_PATH=./data/dominance.db

PERPLEXITY_API_KEY=
OPENAI_API_KEY=

# ε-greedy exploration rate for adaptive answers (0–1). Decay forces explore regardless.
DOMINANCE_EXPLORE_RATE=0.2

# Auto-push learned pack to Cloudflare KV (same key as VigilNode worker: godmode:patch:{domain})
EDGE_DEPLOY_MIN_SCORE=60
# Worker URL (no trailing slash) — primary path: POST /inject + TRUST_GRAPH index
CF_WORKER_URL=https://source-wave-edge-injector.<subdomain>.workers.dev
# Shared secret with Worker EDGE_INJECT_API_KEY (also accepts CF_API_KEY / CF_INJECT_API_KEY)
EDGE_INJECT_API_KEY=
CF_API_TOKEN=
CF_ACCOUNT_ID=
CF_KV_TRUST_GRAPH=

# Optional fallback when KV not configured
# EDGE_DEPLOY_WEBHOOK_URL=https://...

# Optional: BullMQ worker (omit = in-process async jobs)
# REDIS_URL=redis://localhost:6379

# Optional: cap prompts per audit after intent priority sort (cost / ROI control)
# AUDIT_MAX_PROMPTS=8

# Automation: cron expression for `npm run run:clients:schedule` (default = hourly)
# CLIENT_CRON_SCHEDULE=0 * * * *

# --- Client proof emails (`npm run send:reports`, also after each scheduled run) ---
# Gmail-style (default EMAIL_SERVICE=gmail) or set EMAIL_HOST + EMAIL_PORT for SMTP
# EMAIL_SERVICE=gmail
# EMAIL_USER=
# EMAIL_PASS=   # app password for Gmail
# EMAIL_FROM=   # optional; defaults to EMAIL_USER
# EMAIL_HOST=
# EMAIL_PORT=587
# EMAIL_SECURE=0

# --- Outcome distribution (Step 4): GitHub Pages + static /ai/ on Vite app ---
# Fine-grained PAT or classic token with repo scope (Contents: read/write)
GITHUB_TOKEN=
# Repo owner (same as GitHub username for personal accounts)
GITHUB_USERNAME=
GITHUB_REPO=
# Branch to commit files to (default: main)
# GITHUB_PAGES_BRANCH=main
# Path inside repo before filename. Default when unset: ai → files at ai/*.html (URLs …/ai/….html).
# Set to empty for repository root: GITHUB_PAGES_PATH=
# GITHUB_PAGES_PATH=docs
# Optional: full site origin if not https://USER.github.io/REPO
# GITHUB_PAGES_SITE_BASE=https://yourname.github.io/your-repo
#
# Public origin for generated /ai/*.html (no trailing slash).
# Production (primary authority):
SITE_PUBLIC_BASE=https://hiveclick.net
# Local Vite only — comment out SITE_PUBLIC_BASE above and optionally set:
# BLOG_PUBLIC_BASE=http://localhost:5174 local use

# --- Vercel / CI: client `npm run build` runs repo `npm run run:clients` first ---
# Requires monorepo deps: set Install Command to install repo root + client, e.g.
#   cd .. && npm ci && cd client && npm ci
# (when Project Root is `client`), OR set Project Root to repo and output `client/dist`.
# API keys must be present in the deployment env or generation fails.
# To build from committed `client/public/ai/*.html` only:
# SKIP_AI_PAGE_GENERATE=1
